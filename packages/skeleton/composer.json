{
  "name": "gemriser/skeleton",
  "description": "GEMRISER skeleton application",
  "type": "project",
  "license": "GPL-2.0-only",
  "require": {
    "php": "^8.3",
    "gemriser/framework": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
